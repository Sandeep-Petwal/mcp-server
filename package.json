{
  "name": "mcp-server",
  "module": "Server/stdioMcpServer.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "inspact:stdio": "DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector bun run dev:stdio",
    "inspact:http": "npx @modelcontextprotocol/inspector http://localhost:3000/mcp",
    "start:stdio": "bun run Server/stdioMcpServer.ts",
    "start:http": "bun run Server/httpMcpServer.ts",
    "dev:stdio": "nodemon --exec bun run Server/stdioMcpServer.ts",
    "dev:http": "nodemon --exec bun run Server/httpMcpServer.ts",
    
    "dev:client": "bun --watch Client/mcpClient.ts",
    "start:client": "bun run Client/mcpClient.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "nodemon": "^3.1.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.27.0"
  }
}
